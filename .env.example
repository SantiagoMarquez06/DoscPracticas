# ============================================
# Variables de Entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- SQL Server / SSMS ---
# En Docker Compose/Coolify se levanta un contenedor SQL Server llamado "sqlserver".
DB_HOST=sqlserver
DB_PORT=1433
DB_NAME=tienda
DB_USER=sa
DB_PASSWORD=
DB_DIALECT=mssql
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_INSTANCE=
# Debe ser una clave fuerte para SQL Server: mayuscula, minuscula, numero y simbolo.
# Ejemplo local: Herramientas123..
MSSQL_PID=Express
# Solo se usa con docker-compose.local.yml para conectarte desde SSMS local.
SQLSERVER_PORT=1433

# --- Backend (Node API) ---
NODE_ENV=production
DB_SYNC_ALTER=false
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=5000
JWT_SECRET=
CORS_ORIGIN=
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=

# --- Frontend (React + Vite) ---
# Solo se usa con docker-compose.local.yml. En Coolify no publiques el puerto 80 del host.
FRONTEND_PORT=8080
VITE_API_URL=/api
VITE_DEV_API_PROXY_TARGET=

# ============================================
# Notas para Coolify:
# - El compose levanta SQL Server, backend y frontend.
# - No hagas bind del puerto 80 del host; Coolify ya lo usa para su proxy.
# - Configura el dominio de Coolify hacia el servicio frontend, puerto interno 80.
# - SQL Server queda interno en Coolify; no hagas bind del puerto 1433 del host.
# - Para conectarte por SSMS en local usa docker-compose.local.yml.
# - CORS_ORIGIN debe apuntar al dominio publico
#   del frontend (ej: https://tudominio.com).
# - JWT_SECRET debe ser un valor unico y seguro.
# - ADMIN_EMAIL y ADMIN_PASSWORD crean/actualizan el admin inicial al arrancar la API.
# - No subas archivos .env, credenciales ni tokens.
# ============================================
