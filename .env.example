# ============================================
# Variables de Entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- SQL Server / SSMS ---
# Si usas Docker Desktop y SQL Server corre en Windows, deja host.docker.internal.
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=tienda
DB_USER=
DB_PASSWORD=
DB_DIALECT=mssql
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
# Solo si usas instancia nombrada, por ejemplo SQLEXPRESS.
# Si defines DB_INSTANCE, normalmente puedes dejar DB_PORT vacio.
DB_INSTANCE=

# --- Backend (Node API) ---
API_PORT=3000
NODE_ENV=production
DB_SYNC_ALTER=false
JWT_SECRET=
CORS_ORIGIN=

# --- Frontend (React + Vite) ---
FRONTEND_PORT=8080
VITE_API_URL=/api
VITE_DEV_API_PROXY_TARGET=

# ============================================
# Notas para Coolify:
# - Para SQL Server externo, DB_HOST debe apuntar al host alcanzable
#   desde el contenedor. En Docker Desktop local suele ser host.docker.internal.
# - CORS_ORIGIN debe apuntar al dominio publico
#   del frontend (ej: https://tudominio.com).
# - JWT_SECRET debe ser un valor unico y seguro.
# - No subas archivos .env, credenciales ni tokens.
# ============================================
