# ============================================
# Variables de Entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- SQL Server / SSMS ---
# En Docker Compose/Coolify se levanta un contenedor SQL Server llamado "sqlserver".
DB_HOST=sqlserver
DB_PORT=1433
DB_NAME=tienda
DB_USER=sa
DB_PASSWORD=
DB_DIALECT=mssql
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_INSTANCE=
# Debe ser una clave fuerte para SQL Server: mayuscula, minuscula, numero y simbolo.
# Ejemplo local: Herramientas123..
MSSQL_PID=Express
SQLSERVER_PORT=1433

# --- Backend (Node API) ---
NODE_ENV=production
DB_SYNC_ALTER=false
JWT_SECRET=
CORS_ORIGIN=
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=

# --- Frontend (React + Vite) ---
FRONTEND_PORT=8080
VITE_API_URL=/api
VITE_DEV_API_PROXY_TARGET=

# ============================================
# Notas para Coolify:
# - El compose levanta SQL Server, backend y frontend.
# - Publica solo el servicio frontend; Nginx envia /api y /docs al backend interno.
# - Si quieres conectarte con SSMS desde tu PC, usa la IP/dominio de la VM y SQLSERVER_PORT.
# - Abre el puerto 1433 en el firewall solo si realmente necesitas acceso externo.
# - CORS_ORIGIN debe apuntar al dominio publico
#   del frontend (ej: https://tudominio.com).
# - JWT_SECRET debe ser un valor unico y seguro.
# - ADMIN_EMAIL y ADMIN_PASSWORD crean/actualizan el admin inicial al arrancar la API.
# - No subas archivos .env, credenciales ni tokens.
# ============================================
