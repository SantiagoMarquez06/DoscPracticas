# ============================================
# Variables de Entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- PostgreSQL ---
DB_NAME=herramientas_app
DB_USER=sys
DB_PASSWORD=
DB_PORT_EXTERNAL=5432

# --- Backend (Node API) ---
API_PORT=3000
NODE_ENV=production
DB_SYNC_ALTER=false
JWT_SECRET=
CORS_ORIGIN=

# --- Frontend (React + Vite) ---
FRONTEND_PORT=8080
VITE_API_URL=/api
VITE_DEV_API_PROXY_TARGET=

# ============================================
# Notas para Coolify:
# - Las variables DB_HOST y DB_PORT del backend
#   apuntan al servicio interno "db:5432".
# - CORS_ORIGIN debe apuntar al dominio publico
#   del frontend (ej: https://tudominio.com).
# - JWT_SECRET debe ser un valor unico y seguro.
# - No subas archivos .env, credenciales ni tokens.
# ============================================
